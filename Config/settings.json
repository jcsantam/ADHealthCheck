{
  "Version": "2.0.0",
  "Description": "AD Health Check configuration",

  "Scoring": {
    "BaseScore": 100,
    "MaxPenalty": 100,
    "SeverityWeights": {
      "critical": 15,
      "high": 7,
      "medium": 3,
      "low": 1,
      "informational": 0
    },
    "GradeThresholds": {
      "A": 90,
      "B": 80,
      "C": 70,
      "D": 60,
      "F": 0
    }
  },

  "Execution": {
    "MaxParallelJobs": 10,
    "DefaultTimeoutSeconds": 120,
    "RetryFailedChecks": false,
    "MaxRetries": 1
  },

  "Logging": {
    "DefaultLevel": "Information",
    "MaxLogAgeDays": 30,
    "DatabaseVerbosity": "Verbose"
  },

  "Reporting": {
    "AutoOpenReport": true,
    "ReportRetentionDays": 90,
    "IncludeCategoryBreakdown": true,
    "IncludeRawDetails": false
  },

  "Categories": {
    "Enabled": [
      "Replication",
      "DCHealth",
      "DNS",
      "GPO",
      "Time",
      "Backup",
      "Security",
      "Database",
      "Operational"
    ]
  }
}

[
  {
    "CheckId": "REP-001",
    "CheckName": "Replication Status",
    "Category": "Replication",
    "ScriptPath": "Test-ReplicationStatus.ps1",
    "Severity": "critical",
    "Description": "Verifies AD replication is functioning between all DC partners",
    "CriticalThreshold": 0,
    "WarningThreshold": 1,
    "PassMessage": "All replication partnerships are healthy",
    "FailMessage": "Replication failures detected between domain controllers",
    "EvaluationRules": [
      {
        "RuleId": "REP-001-FAIL",
        "Description": "Any replication partner shows Failed status",
        "Condition": "Any(Status == 'Failed')",
        "Status": "Fail",
        "Severity": "critical",
        "Message": "Replication failure detected - immediate action required"
      },
      {
        "RuleId": "REP-001-LASTRESULT-FAIL",
        "Description": "Any replication partner last sync result is failed",
        "Condition": "Any(LastSyncResult == 'Failed')",
        "Status": "Fail",
        "Severity": "critical",
        "Message": "Replication last sync result shows failure"
      },
      {
        "RuleId": "REP-001-CONSECUTIVE",
        "Description": "Any partner has consecutive failures",
        "Condition": "Any(ConsecutiveFailures > 0)",
        "Status": "Fail",
        "Severity": "critical",
        "Message": "Consecutive replication failures detected"
      },
      {
        "RuleId": "REP-001-HASISSUE",
        "Description": "Any partner has issue flag set",
        "Condition": "Any(HasIssue == true)",
        "Status": "Fail",
        "Severity": "critical",
        "Message": "Replication partner has reported an issue"
      },
      {
        "RuleId": "REP-001-ISUNHEALTHY",
        "Description": "Root IsHealthy flag is false",
        "Condition": "IsHealthy == false",
        "Status": "Fail",
        "Severity": "critical",
        "Message": "Replication health check reported failures"
      }
    ]
  },
  {
    "CheckId": "REP-002",
    "CheckName": "Replication Errors",
    "Category": "Replication",
    "ScriptPath": "Test-ReplicationErrors.ps1",
    "Severity": "high",
    "Description": "Checks for replication error events in the Directory Service event log",
    "CriticalThreshold": 5,
    "WarningThreshold": 1,
    "PassMessage": "No replication errors detected",
    "FailMessage": "Replication errors found in event log",
    "EvaluationRules": [
      {
        "RuleId": "REP-002-ERRORCOUNT",
        "Description": "Error count is above zero",
        "Condition": "ErrorCount > 0",
        "Status": "Fail",
        "Severity": "high",
        "Message": "Replication error events found in Directory Service log"
      },
      {
        "RuleId": "REP-002-HASISSUE",
        "Description": "HasIssue flag is true",
        "Condition": "HasIssue == true",
        "Status": "Fail",
        "Severity": "high",
        "Message": "Replication errors detected"
      },
      {
        "RuleId": "REP-002-ISUNHEALTHY",
        "Description": "IsHealthy flag is false",
        "Condition": "IsHealthy == false",
        "Status": "Fail",
        "Severity": "high",
        "Message": "Replication error check failed"
      }
    ]
  },
  {
    "CheckId": "REP-003",
    "CheckName": "USN Rollback Detection",
    "Category": "Replication",
    "ScriptPath": "Test-USNRollback.ps1",
    "Severity": "critical",
    "Description": "Detects USN rollback conditions which cause serious replication issues",
    "CriticalThreshold": 0,
    "WarningThreshold": 0,
    "PassMessage": "No USN rollback detected",
    "FailMessage": "USN rollback detected - immediate investigation required",
    "EvaluationRules": [
      {
        "RuleId": "REP-003-ROLLBACK",
        "Description": "RollbackDetected flag is true on any DC",
        "Condition": "Any(RollbackDetected == true)",
        "Status": "Fail",
        "Severity": "critical",
        "Message": "USN rollback detected - replication will be broken"
      },
      {
        "RuleId": "REP-003-HASISSUE",
        "Description": "Any DC has issue flag set",
        "Condition": "Any(HasIssue == true)",
        "Status": "Fail",
        "Severity": "critical",
        "Message": "USN rollback issue detected on domain controller"
      },
      {
        "RuleId": "REP-003-ISUNHEALTHY",
        "Description": "Root IsHealthy flag is false",
        "Condition": "IsHealthy == false",
        "Status": "Fail",
        "Severity": "critical",
        "Message": "USN rollback check failed"
      }
    ]
  }
]

[
  {
    "CheckId": "TIME-001",
    "CheckName": "PDC Time Source",
    "Category": "Time",
    "ScriptPath": "Test-PDCTimeSource.ps1",
    "Severity": "critical",
    "Description": "Verifies the PDC Emulator is configured with a reliable external NTP time source",
    "CriticalThreshold": 0,
    "WarningThreshold": 0,
    "PassMessage": "PDC Emulator has a valid external time source configured",
    "FailMessage": "PDC Emulator is missing a reliable external NTP time source",
    "EvaluationRules": [
      {
        "RuleId": "TIME-001-NOEXTERNALSOURCE",
        "Description": "HasExternalSource is false",
        "Condition": "HasExternalSource == false",
        "Status": "Fail",
        "Severity": "critical",
        "Message": "PDC Emulator has no external NTP time source configured"
      },
      {
        "RuleId": "TIME-001-NOTRELIABLE",
        "Description": "IsReliable is false",
        "Condition": "IsReliable == false",
        "Status": "Fail",
        "Severity": "critical",
        "Message": "PDC Emulator time source is not reliable"
      },
      {
        "RuleId": "TIME-001-HASISSUE",
        "Description": "HasIssue flag is true",
        "Condition": "HasIssue == true",
        "Status": "Fail",
        "Severity": "critical",
        "Message": "PDC time source issue detected"
      },
      {
        "RuleId": "TIME-001-ISUNHEALTHY",
        "Description": "IsHealthy flag is false",
        "Condition": "IsHealthy == false",
        "Status": "Fail",
        "Severity": "critical",
        "Message": "PDC time source check reported failure"
      }
    ]
  },
  {
    "CheckId": "TIME-002",
    "CheckName": "DC Time Offset",
    "Category": "Time",
    "ScriptPath": "Test-DCTimeOffset.ps1",
    "Severity": "high",
    "Description": "Checks that all DCs have time offset within Kerberos tolerance (5 minutes)",
    "CriticalThreshold": 300,
    "WarningThreshold": 60,
    "PassMessage": "All DC time offsets are within acceptable range",
    "FailMessage": "DC time offset exceeds Kerberos tolerance",
    "EvaluationRules": [
      {
        "RuleId": "TIME-002-CRITICAL-OFFSET",
        "Description": "OffsetSeconds exceeds Kerberos limit (300s)",
        "Condition": "Any(OffsetSeconds > 300)",
        "Status": "Fail",
        "Severity": "critical",
        "Message": "DC time offset exceeds 5-minute Kerberos tolerance - authentication failures imminent"
      },
      {
        "RuleId": "TIME-002-WARN-OFFSET",
        "Description": "OffsetSeconds exceeds warning threshold (60s)",
        "Condition": "Any(OffsetSeconds > 60)",
        "Status": "Warning",
        "Severity": "high",
        "Message": "DC time offset exceeds 60-second warning threshold"
      },
      {
        "RuleId": "TIME-002-WITHIN-TOLERANCE",
        "Description": "Any DC WithinTolerance is false",
        "Condition": "Any(WithinTolerance == false)",
        "Status": "Fail",
        "Severity": "critical",
        "Message": "DC time offset is outside Kerberos tolerance"
      },
      {
        "RuleId": "TIME-002-HASISSUE",
        "Description": "Any DC HasIssue flag set",
        "Condition": "Any(HasIssue == true)",
        "Status": "Fail",
        "Severity": "high",
        "Message": "DC time offset issue detected"
      },
      {
        "RuleId": "TIME-002-ISUNHEALTHY",
        "Description": "Root IsHealthy flag is false",
        "Condition": "IsHealthy == false",
        "Status": "Fail",
        "Severity": "high",
        "Message": "DC time offset check reported failure"
      }
    ]
  }
]

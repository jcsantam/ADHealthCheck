{
  "Category": "GPO",
  "Description": "Group Policy Object health and consistency checks",
  "Version": "2.0",
  "Checks": [
    {
      "CheckId": "GPO-001",
      "CheckName": "Orphaned GPO Detection",
      "Category": "GPO",
      "Severity": "High",
      "ScriptPath": "Test-OrphanedGPOs.ps1",
      "PassMessage": "No orphaned or inconsistent GPOs detected",
      "FailMessage": "Orphaned or inconsistent GPOs detected",
      "EvaluationRules": [
        {
          "RuleId": "GPO-001-MISSING-SYSVOL",
          "Condition": "Any(OrphanType == 'Missing from SYSVOL')",
          "Status": "Fail",
          "Severity": "high",
          "Message": "GPO exists in Active Directory but not in SYSVOL"
        },
        {
          "RuleId": "GPO-001-MISSING-AD",
          "Condition": "Any(OrphanType == 'Missing from AD')",
          "Status": "Fail",
          "Severity": "high",
          "Message": "GPO folder exists in SYSVOL but not in Active Directory"
        },
        {
          "RuleId": "GPO-001-VERSION-MISMATCH",
          "Condition": "Any(OrphanType == 'Version Mismatch')",
          "Status": "Warning",
          "Severity": "medium",
          "Message": "GPO version numbers differ between AD and SYSVOL"
        },
        {
          "RuleId": "GPO-001-EMPTY-UNLINKED",
          "Condition": "Any(OrphanType == 'Empty and Unlinked')",
          "Status": "Warning",
          "Severity": "low",
          "Message": "Empty unlinked GPO detected - cleanup candidate"
        },
        {
          "RuleId": "GPO-001-HASISSUE",
          "Condition": "Any(HasIssue == true)",
          "Status": "Fail",
          "Severity": "high",
          "Message": "GPO issue detected"
        },
        {
          "RuleId": "GPO-001-ISUNHEALTHY",
          "Condition": "IsHealthy == false",
          "Status": "Fail",
          "Severity": "high",
          "Message": "GPO health check reported failure"
        }
      ],
      "IsEnabled": true,
      "Version": "2.0"
    },
    {
      "CheckId": "GPO-002",
      "CheckName": "GPO Replication Consistency",
      "Category": "GPO",
      "Severity": "High",
      "ScriptPath": "Test-GPOReplication.ps1",
      "PassMessage": "All GPO versions are consistent between AD and SYSVOL",
      "FailMessage": "GPO replication inconsistencies detected",
      "EvaluationRules": [
        {
          "RuleId": "GPO-002-USER-MISMATCH",
          "Condition": "Any(UserMismatch == true)",
          "Status": "Warning",
          "Severity": "high",
          "Message": "GPO user policy version mismatch between AD and SYSVOL"
        },
        {
          "RuleId": "GPO-002-COMPUTER-MISMATCH",
          "Condition": "Any(ComputerMismatch == true)",
          "Status": "Warning",
          "Severity": "high",
          "Message": "GPO computer policy version mismatch between AD and SYSVOL"
        },
        {
          "RuleId": "GPO-002-HASISSUE",
          "Condition": "Any(HasIssue == true)",
          "Status": "Warning",
          "Severity": "high",
          "Message": "GPO replication inconsistency detected"
        }
      ],
      "IsEnabled": true,
      "Version": "2.0"
    },
    {
      "CheckId": "GPO-003",
      "CheckName": "SYSVOL Consistency",
      "Category": "GPO",
      "Severity": "High",
      "ScriptPath": "Test-SYSVOLConsistency.ps1",
      "PassMessage": "SYSVOL GPO content is consistent across all DCs",
      "FailMessage": "SYSVOL inconsistencies detected across domain controllers",
      "EvaluationRules": [
        {
          "RuleId": "GPO-003-INCONSISTENT-DC",
          "Condition": "Any(InconsistentDCs > 0)",
          "Status": "Fail",
          "Severity": "high",
          "Message": "SYSVOL GPO content inconsistent across domain controllers"
        },
        {
          "RuleId": "GPO-003-HASISSUE",
          "Condition": "Any(HasIssue == true)",
          "Status": "Fail",
          "Severity": "high",
          "Message": "SYSVOL consistency issue detected"
        }
      ],
      "IsEnabled": true,
      "Version": "2.0"
    },
    {
      "CheckId": "GPO-004",
      "CheckName": "GPO Permissions",
      "Category": "GPO",
      "Severity": "Medium",
      "ScriptPath": "Test-GPOPermissions.ps1",
      "PassMessage": "All GPO permissions are correctly configured",
      "FailMessage": "GPO permission issues detected",
      "EvaluationRules": [
        {
          "RuleId": "GPO-004-PERMISSION-ISSUES",
          "Condition": "Any(GPOsWithIssues > 0)",
          "Status": "Warning",
          "Severity": "medium",
          "Message": "One or more GPOs have permission configuration issues"
        },
        {
          "RuleId": "GPO-004-HASISSUE",
          "Condition": "Any(HasIssue == true)",
          "Status": "Warning",
          "Severity": "medium",
          "Message": "GPO permission issue detected"
        }
      ],
      "IsEnabled": true,
      "Version": "2.0"
    },
    {
      "CheckId": "GPO-005",
      "CheckName": "WMI Filter Validation",
      "Category": "GPO",
      "Severity": "Low",
      "ScriptPath": "Test-WMIFilters.ps1",
      "PassMessage": "All WMI filters are valid and linked to active GPOs",
      "FailMessage": "WMI filter issues detected",
      "EvaluationRules": [
        {
          "RuleId": "GPO-005-ORPHANED",
          "Condition": "Any(OrphanedWMIFilters > 0)",
          "Status": "Warning",
          "Severity": "low",
          "Message": "Orphaned WMI filters detected - not linked to any GPO (cleanup candidates)"
        },
        {
          "RuleId": "GPO-005-HASISSUE",
          "Condition": "Any(HasIssue == true)",
          "Status": "Warning",
          "Severity": "low",
          "Message": "WMI filter issue detected"
        }
      ],
      "IsEnabled": true,
      "Version": "2.0"
    },
    {
      "CheckId": "GPO-007",
      "CheckName": "Empty GPO Detection",
      "Category": "GPO",
      "Severity": "Low",
      "ScriptPath": "Test-EmptyGPOs.ps1",
      "PassMessage": "No empty GPOs detected",
      "FailMessage": "Empty GPOs detected - cleanup candidates",
      "EvaluationRules": [
        {
          "RuleId": "GPO-007-EMPTY",
          "Condition": "Any(IsEmpty == true)",
          "Status": "Warning",
          "Severity": "low",
          "Message": "One or more GPOs have no settings (Computer and User DSVersion both 0)"
        },
        {
          "RuleId": "GPO-007-HASISSUE",
          "Condition": "Any(HasIssue == true)",
          "Status": "Warning",
          "Severity": "low",
          "Message": "Empty GPO detected - review and remove if no longer needed"
        }
      ],
      "IsEnabled": true,
      "Version": "2.0"
    },
    {
      "CheckId": "GPO-008",
      "CheckName": "Disabled GPO Links",
      "Category": "GPO",
      "Severity": "Low",
      "ScriptPath": "Test-DisabledGPOLinks.ps1",
      "PassMessage": "No disabled GPO links detected",
      "FailMessage": "Disabled GPO links detected",
      "EvaluationRules": [
        {
          "RuleId": "GPO-008-DISABLED-LINK",
          "Condition": "Any(LinkOption == 1)",
          "Status": "Warning",
          "Severity": "low",
          "Message": "One or more GPO links are disabled (LinkOption=1) - cleanup candidates"
        },
        {
          "RuleId": "GPO-008-DISABLED-ENFORCED-LINK",
          "Condition": "Any(LinkOption == 3)",
          "Status": "Warning",
          "Severity": "low",
          "Message": "One or more GPO links are disabled and enforced (LinkOption=3)"
        },
        {
          "RuleId": "GPO-008-HASISSUE",
          "Condition": "Any(HasIssue == true)",
          "Status": "Warning",
          "Severity": "low",
          "Message": "Disabled GPO link detected - review and remove if no longer needed"
        }
      ],
      "IsEnabled": true,
      "Version": "2.0"
    },
    {
      "CheckId": "GPO-009",
      "CheckName": "Blocked GPO Inheritance",
      "Category": "GPO",
      "Severity": "Low",
      "ScriptPath": "Test-BlockedInheritance.ps1",
      "PassMessage": "No OUs with blocked GPO inheritance detected",
      "FailMessage": "OUs with blocked GPO inheritance detected",
      "EvaluationRules": [
        {
          "RuleId": "GPO-009-BLOCKED",
          "Condition": "Any(IsBlocked == true)",
          "Status": "Warning",
          "Severity": "low",
          "Message": "One or more OUs have GPO inheritance blocked - verify this is intentional"
        },
        {
          "RuleId": "GPO-009-HASISSUE",
          "Condition": "Any(HasIssue == true)",
          "Status": "Warning",
          "Severity": "low",
          "Message": "Blocked GPO inheritance detected"
        }
      ],
      "IsEnabled": true,
      "Version": "2.0"
    },
    {
      "CheckId": "GPO-010",
      "CheckName": "GPO Link Order Analysis",
      "Category": "GPO",
      "Severity": "Medium",
      "ScriptPath": "Test-GPOLinkOrder.ps1",
      "PassMessage": "No duplicate or excessive GPO links detected",
      "FailMessage": "GPO link order issues detected",
      "EvaluationRules": [
        {
          "RuleId": "GPO-010-DUPLICATE",
          "Condition": "Any(IsDuplicate == true)",
          "Status": "Warning",
          "Severity": "medium",
          "Message": "Duplicate GPO links detected - same GPO linked more than once to the same container"
        },
        {
          "RuleId": "GPO-010-EXCESSIVE",
          "Condition": "Any(LinkCount > 20)",
          "Status": "Warning",
          "Severity": "low",
          "Message": "Container has more than 20 GPO links - may impact logon and startup performance"
        },
        {
          "RuleId": "GPO-010-HASISSUE",
          "Condition": "Any(HasIssue == true)",
          "Status": "Warning",
          "Severity": "medium",
          "Message": "GPO link order issue detected"
        }
      ],
      "IsEnabled": true,
      "Version": "2.0"
    },
    {
      "CheckId": "GPO-011",
      "CheckName": "Cross-Domain GPO Links",
      "Category": "GPO",
      "Severity": "Medium",
      "ScriptPath": "Test-CrossDomainGPOLinks.ps1",
      "PassMessage": "No cross-domain GPO links detected",
      "FailMessage": "Cross-domain GPO links detected",
      "EvaluationRules": [
        {
          "RuleId": "GPO-011-CROSS-DOMAIN",
          "Condition": "Any(HasIssue == true)",
          "Status": "Warning",
          "Severity": "medium",
          "Message": "Cross-domain GPO links detected - GPOs from another domain are linked in this domain"
        }
      ],
      "IsEnabled": true,
      "Version": "2.0"
    }
  ]
}
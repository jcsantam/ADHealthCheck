[
  {
    "CheckId": "DC-001",
    "CheckName": "Critical Services Status",
    "Category": "DCHealth",
    "ScriptPath": "Test-CriticalServices.ps1",
    "Severity": "critical",
    "Description": "Verifies critical AD services are running on all domain controllers",
    "CriticalThreshold": 0,
    "WarningThreshold": 0,
    "PassMessage": "All critical services are running on all DCs",
    "FailMessage": "One or more critical services are stopped",
    "EvaluationRules": [
      {
        "RuleId": "DC-001-STOPPED-STATUS",
        "Description": "Any service Status is Stopped",
        "Condition": "Any(Status == 'Stopped')",
        "Status": "Fail",
        "Severity": "critical",
        "Message": "Critical service stopped on a domain controller"
      },
      {
        "RuleId": "DC-001-NOTRUNNING",
        "Description": "Any service IsRunning is false",
        "Condition": "Any(IsRunning == false)",
        "Status": "Fail",
        "Severity": "critical",
        "Message": "Critical service not in running state"
      },
      {
        "RuleId": "DC-001-ISUNHEALTHY",
        "Description": "IsHealthy flag is false",
        "Condition": "IsHealthy == false",
        "Status": "Fail",
        "Severity": "critical",
        "Message": "Critical services check reported failure"
      }
    ]
  },
  {
    "CheckId": "DC-002",
    "CheckName": "Disk Space",
    "Category": "DCHealth",
    "ScriptPath": "Test-DiskSpace.ps1",
    "Severity": "high",
    "Description": "Checks available disk space on all domain controllers",
    "CriticalThreshold": 5,
    "WarningThreshold": 15,
    "PassMessage": "Disk space is adequate on all DCs",
    "FailMessage": "Low disk space detected on one or more DCs",
    "EvaluationRules": [
      {
        "RuleId": "DC-002-CRITICAL-GB",
        "Description": "FreeSpaceGB below critical threshold (5GB)",
        "Condition": "Any(FreeSpaceGB < 5)",
        "Status": "Fail",
        "Severity": "critical",
        "Message": "Critical: disk space below 5GB on a domain controller"
      },
      {
        "RuleId": "DC-002-WARN-PCT",
        "Description": "FreeSpacePercent below warning threshold (15%)",
        "Condition": "Any(FreeSpacePercent < 15)",
        "Status": "Warning",
        "Severity": "high",
        "Message": "Warning: disk free space below 15% on a domain controller"
      },
      {
        "RuleId": "DC-002-HASISSUE",
        "Description": "Any drive HasIssue flag set",
        "Condition": "Any(HasIssue == true)",
        "Status": "Fail",
        "Severity": "high",
        "Message": "Disk space issue detected on a domain controller"
      },
      {
        "RuleId": "DC-002-ISUNHEALTHY",
        "Description": "Root IsHealthy flag is false",
        "Condition": "IsHealthy == false",
        "Status": "Fail",
        "Severity": "high",
        "Message": "Disk space check reported failure"
      }
    ]
  },
  {
    "CheckId": "DC-003",
    "CheckName": "DC Reachability",
    "Category": "DCHealth",
    "ScriptPath": "Test-DCReachability.ps1",
    "Severity": "critical",
    "Description": "Verifies all domain controllers are reachable on the network",
    "CriticalThreshold": 0,
    "WarningThreshold": 0,
    "PassMessage": "All domain controllers are reachable",
    "FailMessage": "One or more domain controllers are unreachable",
    "EvaluationRules": [
      {
        "RuleId": "DC-003-PING-FAILED",
        "Description": "Any DC PingSuccess is false",
        "Condition": "Any(PingSuccess == false)",
        "Status": "Fail",
        "Severity": "critical",
        "Message": "Domain controller failed ping check"
      },
      {
        "RuleId": "DC-003-STATUS-UNREACHABLE",
        "Description": "Any DC Status is Unreachable",
        "Condition": "Any(Status == 'Unreachable')",
        "Status": "Fail",
        "Severity": "critical",
        "Message": "Domain controller is unreachable"
      },
      {
        "RuleId": "DC-003-HASISSUE",
        "Description": "Any DC HasIssue flag set",
        "Condition": "Any(IsHealthy == false)",
        "Status": "Fail",
        "Severity": "critical",
        "Message": "Domain controller reachability issue detected"
      },
      {
        "RuleId": "DC-003-ISUNHEALTHY",
        "Description": "Root IsHealthy flag is false",
        "Condition": "IsHealthy == false",
        "Status": "Fail",
        "Severity": "critical",
        "Message": "DC reachability check reported failure"
      }
    ]
  }
]

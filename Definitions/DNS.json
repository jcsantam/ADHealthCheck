[
  {
    "CheckId": "DNS-001",
    "CheckName": "Critical SRV Records",
    "Category": "DNS",
    "ScriptPath": "Test-CriticalSRVRecords.ps1",
    "Severity": "critical",
    "Description": "Verifies critical SRV records required for AD operation exist in DNS",
    "CriticalThreshold": 0,
    "WarningThreshold": 0,
    "PassMessage": "All critical SRV records exist",
    "FailMessage": "One or more critical SRV records are missing",
    "EvaluationRules": [
      {
        "RuleId": "DNS-001-STATUS-MISSING",
        "Description": "Any SRV record Status is Missing",
        "Condition": "Any(Status == 'Missing')",
        "Status": "Fail",
        "Severity": "critical",
        "Message": "Critical SRV record missing from DNS"
      },
      {
        "RuleId": "DNS-001-STATUS-FAIL",
        "Description": "Any SRV record Status is Failed",
        "Condition": "Any(Status == 'Failed')",
        "Status": "Fail",
        "Severity": "critical",
        "Message": "Critical SRV record check failed"
      },
      {
        "RuleId": "DNS-001-RECORDCOUNT-ZERO",
        "Description": "Any SRV record has zero records found",
        "Condition": "Any(RecordCount == 0)",
        "Status": "Fail",
        "Severity": "critical",
        "Message": "Critical SRV record has no entries in DNS"
      },
      {
        "RuleId": "DNS-001-HASISSUE",
        "Description": "Any record HasIssue flag set",
        "Condition": "Any(HasIssue == true)",
        "Status": "Fail",
        "Severity": "critical",
        "Message": "Critical SRV record issue detected"
      },
      {
        "RuleId": "DNS-001-ISUNHEALTHY",
        "Description": "Root IsHealthy flag is false",
        "Condition": "IsHealthy == false",
        "Status": "Fail",
        "Severity": "critical",
        "Message": "Critical SRV records check reported failure"
      }
    ]
  },
  {
    "CheckId": "DNS-002",
    "CheckName": "DNS Zone Health",
    "Category": "DNS",
    "ScriptPath": "Test-DNSZoneHealth.ps1",
    "Severity": "high",
    "Description": "Checks health of all AD-integrated DNS zones",
    "CriticalThreshold": 0,
    "WarningThreshold": 0,
    "PassMessage": "All DNS zones are healthy",
    "FailMessage": "DNS zone health issues detected",
    "EvaluationRules": [
      {
        "RuleId": "DNS-002-STATUS-FAIL",
        "Description": "Any zone Status is not Healthy",
        "Condition": "Any(Status == 'Failed')",
        "Status": "Fail",
        "Severity": "high",
        "Message": "DNS zone is in failed state"
      },
      {
        "RuleId": "DNS-002-STATUS-WARN",
        "Description": "Any zone Status is Warning",
        "Condition": "Any(Status == 'Warning')",
        "Status": "Warning",
        "Severity": "medium",
        "Message": "DNS zone has warnings"
      },
      {
        "RuleId": "DNS-002-HASISSUE",
        "Description": "Any zone HasIssue flag set",
        "Condition": "Any(HasIssue == true)",
        "Status": "Fail",
        "Severity": "high",
        "Message": "DNS zone issue detected"
      },
      {
        "RuleId": "DNS-002-ISUNHEALTHY",
        "Description": "Root IsHealthy flag is false",
        "Condition": "IsHealthy == false",
        "Status": "Fail",
        "Severity": "high",
        "Message": "DNS zone health check reported failure"
      }
    ]
  }
]

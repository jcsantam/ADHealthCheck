[
  {
    "CheckId": "SEC-001",
    "CheckName": "Stale Computer Accounts",
    "Category": "Security",
    "ScriptPath": "Test-StaleComputers.ps1",
    "Severity": "medium",
    "Description": "Detects computer accounts that have not authenticated in 90+ days",
    "CriticalThreshold": 0,
    "WarningThreshold": 0,
    "PassMessage": "No stale computer accounts found",
    "FailMessage": "Stale computer accounts detected",
    "EvaluationRules": [
      {
        "RuleId": "SEC-001-COUNT",
        "Description": "Collection has items (stale computers found)",
        "Condition": "Count > 0",
        "Status": "Fail",
        "Severity": "medium",
        "Message": "Stale computer accounts found (not authenticated in 90+ days)"
      },
      {
        "RuleId": "SEC-001-HASISSUE",
        "Description": "Any computer HasIssue flag set",
        "Condition": "Any(HasIssue == true)",
        "Status": "Fail",
        "Severity": "medium",
        "Message": "Stale computer account issues detected"
      },
      {
        "RuleId": "SEC-001-ISUNHEALTHY",
        "Description": "Root IsHealthy flag is false",
        "Condition": "IsHealthy == false",
        "Status": "Fail",
        "Severity": "medium",
        "Message": "Stale computer account check reported failure"
      }
    ]
  },
  {
    "CheckId": "SEC-002",
    "CheckName": "Privileged Account Monitoring",
    "Category": "Security",
    "ScriptPath": "Test-PrivilegedAccounts.ps1",
    "Severity": "high",
    "Description": "Checks privileged group membership and account security posture",
    "CriticalThreshold": 0,
    "WarningThreshold": 0,
    "PassMessage": "Privileged account security is properly configured",
    "FailMessage": "Privileged account security issues detected",
    "EvaluationRules": [
      {
        "RuleId": "SEC-002-HASISSUE",
        "Description": "Any privileged account HasIssue flag set",
        "Condition": "Any(HasIssue == true)",
        "Status": "Fail",
        "Severity": "high",
        "Message": "Privileged account security issue detected"
      },
      {
        "RuleId": "SEC-002-STATUS-FAIL",
        "Description": "Any account Status is Failed or Warning",
        "Condition": "Any(Status == 'Failed')",
        "Status": "Fail",
        "Severity": "high",
        "Message": "Privileged account check shows failure"
      },
      {
        "RuleId": "SEC-002-STATUS-WARN",
        "Description": "Any account Status is Warning",
        "Condition": "Any(Status == 'Warning')",
        "Status": "Warning",
        "Severity": "medium",
        "Message": "Privileged account security warning detected"
      },
      {
        "RuleId": "SEC-002-ISUNHEALTHY",
        "Description": "Root IsHealthy flag is false",
        "Condition": "IsHealthy == false",
        "Status": "Fail",
        "Severity": "high",
        "Message": "Privileged account monitoring check reported failure"
      }
    ]
  }
]
